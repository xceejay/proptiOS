{
  "name": "proptios-monorepo",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "projects": "./scripts/list-projects.sh",
    "changed": "./scripts/changed-projects.sh",
    "doctor": "./scripts/doctor.sh",
    "bootstrap": "./scripts/bootstrap.sh",
    "check": "./scripts/check.sh",
    "check:changed": "./scripts/check.sh --changed",
    "dev": "./scripts/dev.sh app",
    "dev:app": "pnpm --dir app.proptios.com dev",
    "dev:api-pm": "pnpm --dir api.pm.proptios.com dev",
    "dev:www": "pnpm --dir www.proptios.com dev",
    "dev:api-events": "./scripts/dev.sh api-events",
    "build:app": "pnpm --dir app.proptios.com build",
    "test:app": "pnpm --dir app.proptios.com test",
    "deploy": "./scripts/deploy.sh",
    "deploy:dry-run": "./scripts/deploy.sh --dry-run",
    "sync:target": "./scripts/sync-target.sh",
    "sync:dry-run:app": "./scripts/sync-target.sh --dry-run app",
    "sync:dry-run:api-pm": "./scripts/sync-target.sh --dry-run api-pm",
    "sync:dry-run:www": "./scripts/sync-target.sh --dry-run www",
    "sync:dry-run:api-events": "./scripts/sync-target.sh --dry-run api-events",
    "sync:changed": "./scripts/sync-changed.sh",
    "import:app": "./scripts/import-subtree.sh app.proptios.com git@github.com:xceejay/app.proptios.com.git",
    "import:api-pm": "./scripts/import-subtree.sh api.pm.proptios.com git@github.com:xceejay/api.pm.proptios.com.git",
    "import:www": "./scripts/import-subtree.sh www.proptios.com git@github.com:xceejay/www.proptios.com.git",
    "import:api-events": "./scripts/import-subtree.sh api.events.proptios.com git@github.com:xceejay/api.events.proptios.com.git",
    "sync:app": "./scripts/split-push.sh app.proptios.com git@github.com:xceejay/app.proptios.com.git",
    "sync:api-pm": "./scripts/split-push.sh api.pm.proptios.com git@github.com:xceejay/api.pm.proptios.com.git",
    "sync:www": "./scripts/split-push.sh www.proptios.com git@github.com:xceejay/www.proptios.com.git",
    "sync:api-events": "./scripts/split-push.sh api.events.proptios.com git@github.com:xceejay/api.events.proptios.com.git"
  }
}
